    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructurapublica#OffStreetParking -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructurapublica#OffStreetParking">
        <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructurapublica#MunicipalFacility"/>
        <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructurapublica#Parking"/>
        <rdfs:comment xml:lang="es">Aparcamiento fuera de la vía pública. Incluye instalaciones o superficies de aparcamiento.</rdfs:comment>
        <rdfs:comment xml:lang="en">Off-street parking, including parking facilities or parking surfaces.</rdfs:comment>
        <rdfs:label xml:lang="es">Aparcamiento fuera de la vía pública</rdfs:label>
        <rdfs:label xml:lang="en">Off-street parking</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructurapublica#OnStreetParking -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructurapublica#OnStreetParking">
        <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructurapublica#Parking"/>
        <rdfs:comment xml:lang="es">Aparcamiento en la vía pública que inluye plazas para residentes, no residentes, libres, carga y descarga, entre otros.</rdfs:comment>
        <rdfs:comment xml:lang="en">On-street parking that includes spaces for residents, non-residents, free spaces, loading and unloading, among others.</rdfs:comment>
        <rdfs:label xml:lang="es">Aparcamiento en la vía pública</rdfs:label>
        <rdfs:label xml:lang="en">On-street parking</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructurapublica#OrganizacionExterna -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructurapublica#OrganizacionExterna">
        <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructurapublica#Organization"/>
        <rdfs:comment xml:lang="en">An organization external to the municipal administration that has a role in the management of a municipal facility.</rdfs:comment>
        <rdfs:comment xml:lang="es">Organización externa a la administración municipal que tiene algún rol en la gestión del equipamiento municipal.</rdfs:comment>
        <rdfs:label xml:lang="en">External organization</rdfs:label>
        <rdfs:label xml:lang="es">Organización externa</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructurapublica#Organization -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructurapublica#Organization">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/org#Organization"/>
        <rdfs:comment xml:lang="en">Department of the municipal administration or external organization that manages municipal instalaltionin any role, such as ownership, maintenance, security.</rdfs:comment>
        <rdfs:comment xml:lang="es">Dependencia de la administración municipal u organización externa que gestiona el equipamiento municipal  en cualquier rol, tales como la titularidad, el mantenimiento, la seguridad.</rdfs:comment>
        <rdfs:label xml:lang="es">Organización</rdfs:label>
        <rdfs:label xml:lang="en">Organization</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructurapublica#Parking -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructurapublica#Parking">
        <rdfs:comment xml:lang="es">Aparcamiento para diferentes tipos de vehículo que incluye instalaciones o superficies de aparcamiento fuera de la vía pública o zonas de aparcamiento en la vía pública para residentes, no residentes o libres.</rdfs:comment>
        <rdfs:comment xml:lang="en">Parking for different types of vehicles, including off-street parking facilities or on-street parking zones for residents, non-residents, or free parking.</rdfs:comment>
        <rdfs:label xml:lang="es">Aparcamiento</rdfs:label>
        <rdfs:label xml:lang="en">Parking</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructurapublica#ParkingAccess -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructurapublica#ParkingAccess">
        <rdfs:comment xml:lang="es">Lugar en donde se entra o se sale del aparcamiento.</rdfs:comment>
        <rdfs:comment xml:lang="en">Place where you enter or exit the parking lot.</rdfs:comment>
        <rdfs:label xml:lang="es">Acceso a aparcamiento</rdfs:label>
        <rdfs:label xml:lang="en">Parking access</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructurapublica#ParkingFee -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructurapublica#ParkingFee">
        <rdfs:comment xml:lang="en">Parking fee that essentially covers the right to park the vehicle in an authorized space for a certain time period.</rdfs:comment>
        <rdfs:comment xml:lang="es">Tarifa de un aparcamiento que cubre fundamentalmente el derecho a estacionar el vehículo en un espacio autorizado durante un tiempo determinado.</rdfs:comment>
        <rdfs:label xml:lang="en">Parking fee</rdfs:label>
        <rdfs:label xml:lang="es">Tarifa</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructurapublica#ParkingSpot -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructurapublica#ParkingSpot">
        <rdfs:comment xml:lang="en">Individual parking spot in an on-street or off-street parking.</rdfs:comment>
        <rdfs:comment xml:lang="es">Plaza individual de estacionamiento dentro o fuera de la vía pública.</rdfs:comment>
        <rdfs:label xml:lang="en">Parking spot</rdfs:label>
        <rdfs:label xml:lang="es">Plaza (de aparcamiento)</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructurapublica#ParkingSpotsByVehicleType -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructurapublica#ParkingSpotsByVehicleType">
        <rdfs:comment xml:lang="en">Group of parking spots for each type of vehicle: cars, motorcycles, bicycles, among others. It indicates the number of slots per type.</rdfs:comment>
        <rdfs:comment xml:lang="es">Grupo de plazas de aparcamiento para cada tipo de vehículo: coches, motocicletas, biciletas, entre otros. Indica el número de plazas por tipo.</rdfs:comment>
        <rdfs:label xml:lang="en">Group of parking spots by vehicle type</rdfs:label>
        <rdfs:label xml:lang="es">Grupo de plazas por tipo de vehículo</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructurapublica#SensorAccesoVehiculo -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructurapublica#SensorAccesoVehiculo">
        <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructurapublica#AccessSensor"/>
        <rdfs:label xml:lang="es">Sensor de acceso a vehiculo</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructurapublica#ServicioMunicipal -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructurapublica#ServicioMunicipal">
        <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructurapublica#Organization"/>
        <rdfs:comment xml:lang="es">Administración municipal o cualquiera de sus dependencias que tienen un rol en la gestión de un equipamiento municipal.</rdfs:comment>
        <rdfs:comment xml:lang="en">Municipal administration or any of its departments that have a role in the management of a municipal facility.</rdfs:comment>
        <rdfs:label xml:lang="en">Municipal service</rdfs:label>
        <rdfs:label xml:lang="es">Servicio municipal</rdfs:label>
    </owl:Class>
    


    <!-- http://www.opengis.net/ont/geosparql#Feature -->


    <owl:Class rdf:about="http://www.opengis.net/ont/geosparql#Feature">
        <rdfs:comment xml:lang="es">Esta clase representa el tipo &quot;feature&quot; de nivel superior. Es equivalente a GFI_Feature, definida en la norma ISO 19156:2011, y es la superclase de todos los tipos de &quot;feature&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.0"/>
        <rdfs:label xml:lang="en">Feature</rdfs:label>
    </owl:Class>
    


    <!-- http://www.opengis.net/ont/geosparql#Geometry -->


    <owl:Class rdf:about="http://www.opengis.net/ont/geosparql#Geometry">
        <rdfs:comment xml:lang="es">La clase representa el tipo de geometría de nivel superior. Esta clase es equivalente a la clase UML GM_Object definida en la norma ISO 19107 y es la superclase de todos los tipos de geometría.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.0"/>
        <rdfs:isDefinedBy xml:lang="es">Geometría</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Geometry</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2004/02/skos/core#Concept -->


    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#ConceptScheme -->


    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
    


    <!-- http://www.w3.org/2006/time#TemporaEntity -->


    <owl:Class rdf:about="http://www.w3.org/2006/time#TemporaEntity">
        <rdfs:comment xml:lang="es">Un intervalo temporal o un instante.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2006/time"/>
        <rdfs:label xml:lang="es">Entidad temporal</rdfs:label>
        <rdfs:label xml:lang="en">Temporal entity</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/org#Organization -->


    <owl:Class rdf:about="http://www.w3.org/ns/org#Organization">
        <rdfs:comment xml:lang="es">Grupo de personas que se organiza en una comunidad u otro tipo de estructura social, comercial o política. Dicho grupo tiene un objetivo o motivo común para su existencia que va más allá del conjunto de personas que lo forman y que puede actuar como “agente”. A menudo las organizaciones se pueden agrupar en estructuras jerárquicas. Se recomienda el uso de etiquetas de SKOS para denominar a cada “organización”. En concreto, `skos:prefLabel` para la denominación principal o recomendada (aquella reconocida legalmente, siempre que sea posible), `skos:altLabel` para denominaciones alternativas (nombre comercial, sigla, denominación por la que se conoce a la organización coloquialmente) y `skos:notation` para referirse al código que identifique a la organización en una lista de códigos. Denominaciones alternativas: _colectivo_ _corporación_ _grupo_</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/org"/>
        <rdfs:label xml:lang="es">Organización</rdfs:label>
        <rdfs:label xml:lang="en">Organization</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/sosa/FeatureOfInterest -->


    <owl:Class rdf:about="http://www.w3.org/ns/sosa/FeatureOfInterest">
        <rdfs:comment xml:lang="es">Cosa cuya propiedad se está estimando o calculando en el curso de una Observación para llegar a un Resultado o cuya propiedad está siendo manipulada por un Actuador, o que está siendo muestreada o transformada en un acto de Muestreo.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/sosa/"/>
        <rdfs:label xml:lang="es">Entidad de interés</rdfs:label>
        <rdfs:label xml:lang="en">Feature Of Interest</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/sosa/ObservableProperty -->


    <owl:Class rdf:about="http://www.w3.org/ns/sosa/ObservableProperty">
        <rdfs:comment xml:lang="es">Una cualidad observable (propiedad, característica) de una entidad de interés.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/sosa/"/>
        <rdfs:label xml:lang="es">Propiedad observable</rdfs:label>
        <rdfs:label>Observable Property</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/sosa/Observation -->


    <owl:Class rdf:about="http://www.w3.org/ns/sosa/Observation">
        <rdfs:comment xml:lang="es">Acto de realizar un procedimiento (de observación) para estimar o calcular el valor de una propiedad de una característica de interés. Se vincula a un sensor para describir qué realizó la observación y cómo; se vincula a una propiedad observable para describir de qué propiedad es la estimación del resultado, y a una característica de interés para detallar con qué se asoció esa propiedad.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/sosa/"/>
        <rdfs:label xml:lang="es">Observación</rdfs:label>
        <rdfs:label>Observation</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/sosa/Sensor -->


    <owl:Class rdf:about="http://www.w3.org/ns/sosa/Sensor">
        <rdfs:comment xml:lang="es">Sistema que implementa un procedimiento de observación para determinar el valor de una Propiedad observable.Puede ser un dispositivo, una infraestructura, un agente (incluyendo humanos) o software (simulación). Un sensor responde a un estímulo, por ejemplo, un cambio en el entorno o datos de entrada compuestos por los resultados de observaciones previas.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/sosa/"/>
        <rdfs:label xml:lang="en">Sensor</rdfs:label>
        <rdfs:label xml:lang="es">Sensor</rdfs:label>
    </owl:Class>
    


    <!-- https://saref.etsi.org/saref4bldg/Building -->


    <owl:Class rdf:about="https://saref.etsi.org/saref4bldg/Building">
        <rdfs:comment xml:lang="en">A building represents a structure that provides shelter for its occupants or contents and stands in one place. The building is also used to provide a basic element within the spatial structure hierarchy for the components of a building project (together with site, storey, and space).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://saref.etsi.org/saref4bldg/"/>
        <rdfs:label xml:lang="en">Building</rdfs:label>
    </owl:Class>
    


