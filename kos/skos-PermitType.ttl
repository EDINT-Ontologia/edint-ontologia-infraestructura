@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix cc: <http://creativecommons.org/ns#> .
@prefix edintinfp: <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructurapublica#> .
@prefix edintkos: <http://vocab.linkeddata.es/datosabiertos/kos/edint/> .
@prefix edintpermittype: <http://vocab.linkeddata.es/datosabiertos/kos/edint/PermitType/> .

#################################################################
#
#    Concept Scheme
#
#################################################################

edintkos:PermitType a skos:ConceptScheme ; 
    dct:issued "2026-02-19"^^xsd:date ;
    dct:modified "2026-02-19"^^xsd:date ;
    cc:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "This concept scheme belongs to the set of controlled SKOS-based thesauri used by the ontologies from the EDINT data space."@en ;
    rdfs:comment "Este esquema de conceptos pertenece al conjunto de tesauros SKOS usados por las ontologías del espacio de datos EDINT."@es ;
    rdfs:label "Tipo de permiso para aparcamiento"@en ;
    rdfs:label "Type of parking permit"@es ;
    dct:title "Concept scheme grouping types of permit that are allowed for public parking spots"@en ;
    dct:title "Esquema de conceptos agrupando tipos de permisos que se otorgan para lugares de aparcamiento público"@es .
    

#################################################################
#
#    Concepts
#
#################################################################

edintpermittype:resident a skos:Concept;
  skos:inScheme edintkos:PermitType;
  skos:prefLabel "Residente"@es ;
  skos:prefLabel "Resident"@en .

edintpermittype:commercial a skos:Concept;
  skos:inScheme edintkos:PermitType;
  skos:prefLabel "Comercial"@es ;
  skos:prefLabel "Commercial"@en .

edintpermittype:carsharing a skos:Concept;
  skos:inScheme edintkos:PermitType;
  skos:prefLabel "Coche compartido"@es ;
  skos:prefLabel "Car sharing"@en .

edintpermittype:reducedmobility a skos:Concept;
  skos:inScheme edintkos:PermitType;
  skos:prefLabel "Movilidad reducida"@es ;
  skos:prefLabel "Reduced mobility"@en .

edintpermittype:reducedmobility a skos:Concept;
  skos:inScheme edintkos:PermitType;
  skos:prefLabel "Movilidad reducida"@es ;
  skos:prefLabel "Reduced mobility"@en .

edintpermittype:loadingunloading a skos:Concept;
  skos:inScheme edintkos:PermitType;
  skos:prefLabel "Carga y descarga"@es ;
  skos:prefLabel "Loading and unloading"@en .




