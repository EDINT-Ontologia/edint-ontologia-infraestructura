@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix cc: <http://creativecommons.org/ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix edintinf: <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#> .
@prefix edintkos: <http://vocab.linkeddata.es/datosabiertos/kos/edint/> .
@prefix edintinftype: <http://vocab.linkeddata.es/datosabiertos/kos/edint/InfrastructureType> .
@base <http://www.w3.org/2002/07/owl#> .

#################################################################
#
#    Concept Scheme
#
#################################################################

edintkos:InfrastructureType a skos:ConceptScheme ; 
    dct:issued "2026-03-12"^^xsd:date ;
    cc:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "This concept scheme belongs to the set of controlled SKOS-based thesauri used by the ontologies from the EDINT data space."@en ;
    rdfs:comment "Este esquema de conceptos pertenece al conjunto de tesauros SKOS usados por las ontologías del espacio de datos EDINT."@es ;
    rdfs:label "Tipo de elemento de infraestructura"@en ;
    rdfs:label "Type of infrastructure element"@es ;
    dct:title "Concept scheme grouping types of infrastructure elements"@en ;
    dct:title "Esquema de conceptos que agrupa tipos de elementos de infraestructura"@es ;
    skos:hasTopConcept edintinftype:Facility ;
    skos:hasTopConcept edintinftype:UrbanElement .

#################################################################
#
#    Concepts
#
#################################################################


############ Urban Element

edintinftype:UrbanElement a skos:Concept ;
    skos:inScheme edintkos:InfrastructureType ;
    skos:prefLabel "Elemento urbano"@es ;
    skos:prefLabel  "Urban element"@en .

edintinftype:StreeLamp a skos:Concept ;
    skos:inScheme edintkos:InfrastructureType ;
    skos:broader edintinftype:UrbanElement ; 
    skos:prefLabel "Farola"@es ;
    skos:prefLabel  "Street lamp"@en .

edintinftype:ZebraCrossing a skos:Concept ;
    skos:inScheme edintkos:InfrastructureType ;
    skos:broader edintinftype:UrbanElement ; 
    skos:prefLabel "Paso de cebra"@es ;
    skos:prefLabel  "Zebra crossing"@en .

edintinftype:TrafficLight a skos:Concept ;
    skos:inScheme edintkos:InfrastructureType ;
    skos:broader edintinftype:UrbanElement ; 
    skos:prefLabel "Semáforo"@es ;
    skos:prefLabel  "Traffic light"@en .



##################  Facility

edintinftype:Facility a skos:Concept ;
    skos:inScheme edintkos:InfrastructureType ;
    skos:prefLabel "Equipamiento"@es ;
    skos:prefLabel  "Facility"@en .


##### Terrace

edintinftype:Terrace a skos:Concept ;
    skos:inScheme edintkos:InfrastructureType ;
    skos:broader edintinftype:Facility ; 
    skos:prefLabel "Terraza"@es ;
    skos:prefLabel  "Terrace"@en .

edintinftype:UncoveredTerrace a skos:Concept ;
    skos:inScheme edintkos:InfrastructureType ;
    skos:broader edintinftype:Terrace ; 
    skos:prefLabel "Terraza descubierta"@es ;
    skos:prefLabel  "Uncovered Terrace"@en.

edintinftype:CoveredTerrace a skos:Concept ;
    skos:inScheme edintkos:InfrastructureType ;
    skos:broader edintinftype:Terrace ; 
    skos:prefLabel "Terraza cubierta"@es ;
    skos:prefLabel  "Covered Terrace"@en.

