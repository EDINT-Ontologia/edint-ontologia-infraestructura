  skos:prefLabel "Bar"@es ;
  skos:prefLabel "Bar"@en .

edintkosinftype:Restaurant a skos:Concept ;
  skos:inScheme edintkos:InfrastructureType ;
  skos:broader edintkosinftype:CommercialSpace ;
