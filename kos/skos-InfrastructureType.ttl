  skos:inScheme edintkos:InfrastructureType ;
  skos:broader edintkosinftype:CommercialSpace ;
  skos:prefLabel "Puesto de mercado"@es ;
  skos:prefLabel "Market stall"@en .
	
edintkosinftype:Shop a skos:Concept ;
