@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix cc: <http://creativecommons.org/ns#> .
@prefix edintinfp: <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructurapublica#> .
@prefix edintkos: <http://vocab.linkeddata.es/datosabiertos/kos/edint/> .
@prefix edintmanagementrole: <http://vocab.linkeddata.es/datosabiertos/kos/edint/ManagementRoleType/> .

#################################################################
#
#    Concept Scheme
#
#################################################################

edintkos:ManagementRoleType a skos:ConceptScheme ; 
    dct:issued "2026-02-19"^^xsd:date ;
    dct:modified "2026-02-19"^^xsd:date ;
    cc:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "This concept scheme belongs to the set of controlled SKOS-based thesauri used by the ontologies from the EDINT data space."@en ;
    rdfs:comment "Este esquema de conceptos pertenece al conjunto de tesauros SKOS usados por las ontologías del espacio de datos EDINT."@es ;
    rdfs:label "Tipo de rol de gestión"@en ;
    rdfs:label "Type of management role"@es ;
    dct:title "Concept scheme grouping types of management roles that are exercised by an organization on a facility"@en ;
    dct:title "Esquema de conceptos agrupando tipos de roles de gestión que ejerce una organización sobre un equipamiento"@es .
    

#################################################################
#
#    Concepts
#
#################################################################

edintmanagementrole:basicservices a skos:Concept;
  skos:inScheme edintkos:ManagementRoleType;
  skos:prefLabel "Servicios Básicos"@es ;
  skos:prefLabel "Basic services"@en .

edintmanagementrole:facilitysecurity a skos:Concept;
  skos:inScheme edintkos:ManagementRoleType;
  skos:prefLabel "Seguridad de equipamientos"@es ;
  skos:prefLabel "Facility security"@en .

edintmanagementrole:humanresources a skos:Concept;
  skos:inScheme edintkos:ManagementRoleType;
  skos:prefLabel "Recursos humanos"@es ;
  skos:prefLabel "Human resources"@en .

edintmanagementrole:maintenance a skos:Concept;
  skos:inScheme edintkos:ManagementRoleType;
  skos:prefLabel "Mantenimiento preventivo y correctivo"@es ;
  skos:prefLabel "Preventive and corrective maintenance"@en .



